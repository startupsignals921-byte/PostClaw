{
  "name": "@christopherlittle51/postclaw",
  "version": "1.3.5",
  "description": "OpenClaw native plugin for PostgreSQL-backed RAG, memory, and persona management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "dashboard/public/",
    "schemas/db.sql",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "node dist/test-db.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "postgres",
    "rag",
    "memory",
    "pgvector"
  ],
  "author": "Christopher Little",
  "license": "ISC",
  "type": "commonjs",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@ambientcss/css": "^1.1.1",
    "@sinclair/typebox": "^0.34.48",
    "dotenv": "^17.3.1",
    "postgres": "^3.4.8",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
