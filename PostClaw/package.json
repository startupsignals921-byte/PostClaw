{
  "name": "postclaw",
  "version": "1.0.0",
  "description": "OpenClaw native plugin for PostgreSQL-backed RAG, memory, and persona management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "test:db": "node dist/test-db.js"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "postgres",
    "rag"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@types/node": "^25.3.3",
    "postgres": "^3.4.8",
    "typescript": "^5.9.3"
  }
}
